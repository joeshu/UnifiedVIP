  "htmlReplacements": [
    {
      "pattern": "<meta[^>]*name=[\"']wwads-cn-verify[\"'][^>]*>|<script[^>]*src=[\"'][^\"']*(?:cdn\\.wwads\\.cn|pagead2\\.googlesyndication\\.com|google-analytics\\.com)[^\"']*[\"'][^>]*>[\\s\\S]*?<\\/script>",
      "replacement": "",
      "flags": "gi"
    },
    {
      "pattern": "<div[^>]*id=[\"']pro-campaign-container[\"'][^>]*>[\\s\\S]*?</div>",
      "replacement": "",
      "flags": "gi"
    },
    {
      "pattern": "<div[^>]*class=[\"'][^\"']*wwads[^\"']*[\"'][^>]*>[\\s\\S]*?<\\/div>",
      "replacement": "",
      "flags": "gi"
    },
    {
      "pattern": "</body>",
      "replacement": "<script>(function(){var ads=['.sidebar_units','.sidebar_compliance','.wwads','.adsbygoogle','#pro-campaign-container'];for(var i=0;i<ads.length;i++){var list=document.querySelectorAll(ads[i]);for(var j=0;j<list.length;j++){list[j].remove();}}var s=document.querySelectorAll('script[src*=\"cdn.wwads.cn/js/makemoney.js\"],script[src*=\"pagead2.googlesyndication.com/pagead/js/adsbygoogle.js\"],script[src*=\"google-analytics.com/analytics.js\"]');for(var k=0;k<s.length;k++){s[k].remove();}})();</script></body>",
      "flags": "i"
    }
  ]
}