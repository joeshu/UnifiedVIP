{
  "urlPattern": "^https:\/\/iotpservice\.smartont\.net\/wohome\/dispatcher",
  "id": "wohome",
  "name": "联通智家",
  "mode": "json",
  "processor": {
    "processor": "compose",
    "params": {
      "steps": [
        {
          "processor": "when",
          "params": {
            "condition": "includes",
            "check": "RSP.DATA[0].posCode",
            "value": "APP_START_PAGE",
            "then": {
              "processor": "deleteFields",
              "params": {
                "paths": [
                  "RSP.DATA[0].configList",
                  "RSP.DATA.configList",
                  "data.configList"
                ]
              }
            }
          }
        },
        {
          "processor": "deleteFields",
          "params": {
            "paths": [
              "RSP.DATA.configList"
            ]
          }
        }
      ]
    }
  }
}